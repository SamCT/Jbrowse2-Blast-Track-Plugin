{
  "name": "jbrowse-plugin-blast-track",
  "version": "0.1.0",
  "description": "JBrowse 2 plugin for running NCBI BLAST from feature and region selections and rendering hits as same-view tracks.",
  "license": "GPL-3.0-only",
  "author": "SamCT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SamCT/Jbrowse2-Blast-Track-Plugin.git"
  },
  "bugs": {
    "url": "https://github.com/SamCT/Jbrowse2-Blast-Track-Plugin/issues"
  },
  "homepage": "https://github.com/SamCT/Jbrowse2-Blast-Track-Plugin#readme",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "jbrowse",
    "jbrowse-plugin",
    "blast",
    "ncbi",
    "genomics",
    "bioinformatics"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && node esbuild.mjs",
    "generate:password": "node -e \"console.log(require('node:crypto').randomBytes(24).toString('base64url'))\"",
    "serve:jbrowse": "node scripts/serve-jbrowse.mjs",
    "start": "node esbuild.mjs --watch",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@jbrowse/core": "^4.0.0",
    "@jbrowse/plugin-linear-genome-view": "^4.0.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/cli": "^4.2.1",
    "@jbrowse/core": "^4.2.0",
    "@jbrowse/mobx-state-tree": "^5.6.0",
    "@jbrowse/plugin-linear-genome-view": "^4.2.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "serve": "^14.2.6",
    "typescript": "^6.0.3"
  }
}
